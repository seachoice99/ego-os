OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
TAVILY_API_KEY=

# Owner access control (v0.4.1) -- required. The app fails closed (every
# request gets 401) if either of these is unset, so leaving them blank
# here is deliberate: never commit real values, set them only in the
# real .env (which is gitignored).
OWNER_USERNAME=
OWNER_PASSWORD=
